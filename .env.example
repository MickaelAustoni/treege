# OPEN# AI Configuration for Tree Generation
# Get your API key from one of these providers:
# - Gemini (Recommended): https://aistudio.google.com/
# - OpenAI: https://platform.openai.com/api-keys
# - DeepSeek: https://platform.deepseek.com/
# - Claude: https://console.anthropic.com/
VITE_AI_API_KEY=your-api-key-here

# Optional Bearer token used by the example app to seed the renderer's
# global headers (`Authorization: Bearer <token>`). Useful for testing
# protected APIs without going through the Authorize dialog every time.
VITE_BEARER_TOKEN=

# Optional URL to an OpenAPI 3.x document. When set, the editor auto-loads
# it on mount (equivalent to using the "OpenAPI" button → URL tab).
VITE_OPENAPI_URL=

# Base URL the produced tree runs against. Passed to both the editor
# (`baseUrl` — relative urls are stored, OpenAPI routes resolved, "Detect
# fields" probed against it) and the renderer (`baseUrl`). Works with or
# without OpenAPI. Falls back to VITE_OPENAPI_BASE_URL when unset.
VITE_BASE_URL=

# Deprecated alias kept for backward compatibility. Prefer VITE_BASE_URL.
VITE_OPENAPI_BASE_URL=
